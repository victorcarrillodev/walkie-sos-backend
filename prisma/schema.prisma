// This is your Prisma schema file,
generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- MODELOS ---
// Usuario
model User {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  alias     String   @unique
  email     String   @unique
  password  String   
  avatarUrl String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  ownedChannels   Channel[]       @relation("OwnerChannels")
  memberships     ChannelMember[]
  alertsSent      Alert[]
  alertsReceived  Alert[]         @relation("AlertsReceived")
  
  // Relaciones para el historial de contactos
  contacts        Contact[]       @relation("UserContacts")
  contactedBy     Contact[]       @relation("ContactedUsers")
}

// 2. Historial de Contactos (NUEVO)
// Guarda con quién ha hablado el usuario recientemente
model Contact {
  id              String   @id @default(uuid())
  userId          String
  contactId       String
  lastContactedAt DateTime @default(now()) // Se actualiza cada vez que hablan

  user            User     @relation("UserContacts", fields: [userId], references: [id])
  contactUser     User     @relation("ContactedUsers", fields: [contactId], references: [id])

  // Un usuario solo puede tener a otro usuario una vez en su lista de contactos
  @@unique([userId, contactId]) 
}

// 3. Grupos / Canales (Modificado)
// Actúa como "Grupos" donde puede haber Admins o Miembros
model Channel {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  password    String   
  maxMessageDuration Int @default(60) // NUEVO: Duración en segundos
  isMuted     Boolean  @default(false) // NUEVO: Si true, solo admins pueden hablar
  isGroup     Boolean  @default(true) // NUEVO: Para diferenciar 1-a-1 de Grupos grandes
  
  ownerId     String
  owner       User     @relation("OwnerChannels", fields: [ownerId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     ChannelMember[]
  alerts      Alert[] 
}

// Tabla intermedia para gestionar miembros y roles en el grupo
model ChannelMember {
  id        String     @id @default(uuid())
  userId    String
  channelId String
  role      MemberRole @default(USER) // ADMIN, USER, MODERATOR
  joinedAt  DateTime   @default(now())
  mutedUntil DateTime? // NUEVO: Penalizado hasta esta fecha (null = sin penalización)

  user      User     @relation(fields: [userId], references: [id])
  channel   Channel  @relation(fields: [channelId], references: [id])

  @@unique([userId, channelId]) 
}

// 4. Alerta (Sin cambios)
model Alert {
  id        String      @id @default(uuid())
  type      AlertType   @default(THEFT) 
  status    AlertStatus @default(ACTIVE)
  
  latitude  Float
  longitude Float
  address   String?     

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  channelId String?
  channel   Channel? @relation(fields: [channelId], references: [id])

  targetUserId String?
  targetUser   User?    @relation("AlertsReceived", fields: [targetUserId], references: [id])

  createdAt DateTime @default(now())
  resolvedAt DateTime?
}

// --- ENUMS ---
enum MemberRole {
  ADMIN
  MODERATOR
  USER
}

enum AlertType {
  THEFT       
  PANIC       
  MEDICAL     
  SUSPICIOUS  
}

enum AlertStatus {
  ACTIVE      
  RESOLVED    
  DISMISSED   
}